{
  "name": "@prefabs.tech/saas-react",
  "version": "0.29.0",
  "description": "Saas plugin for react",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/PrefabsTechSaasReact.es.js",
      "require": "./dist/PrefabsTechSaasReact.umd.js"
    },
    "./dist/PrefabsTechSaasReact.css": "./dist/saas-react.css"
  },
  "main": "dist/PrefabsTechSaasReact.umd.js",
  "module": "dist/PrefabsTechSaasReact.es.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "snapshot:update": "vitest --environment jsdom run --update",
    "sort-package": "npx sort-package-json",
    "stylelint": "stylelint \"src/**/*.{css,vue}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"src/**/*.{css,vue}\" --fix --allow-empty-input",
    "test": "pnpm build && vitest --environment jsdom run --coverage --pass-with-no-tests",
    "test:component": "vitest --environment jsdom run component/ --pass-with-no-tests",
    "test:snapshot": "vitest --environment jsdom run snapshot/ --pass-with-no-tests",
    "test:unit": "vitest --environment jsdom run unit/ --pass-with-no-tests",
    "typecheck": "tsc --noEmit -p tsconfig.vitest.json --composite false"
  },
  "dependencies": {
    "axios": "1.12.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@prefabs.tech/eslint-config": "0.7.0",
    "@prefabs.tech/react-config": "0.70.0",
    "@prefabs.tech/react-form": "0.70.0",
    "@prefabs.tech/react-i18n": "0.70.0",
    "@prefabs.tech/react-ui": "0.70.0",
    "@prefabs.tech/stylelint-config": "0.7.0",
    "@types/jsdom": "21.1.7",
    "@types/node": "24.10.15",
    "@types/react": "18.3.28",
    "@vitejs/plugin-react": "4.5.2",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.4",
    "jsdom": "26.0.0",
    "prettier": "3.8.3",
    "primereact": "9.6.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.2",
    "react-toastify": "10.0.6",
    "stylelint": "17.9.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "typescript": "5.7.3",
    "vite": "6.3.7",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "@prefabs.tech/react-config": ">=0.70.0",
    "@prefabs.tech/react-form": ">=0.70.0",
    "@prefabs.tech/react-i18n": ">=0.70.0",
    "@prefabs.tech/react-ui": ">=0.70.0",
    "primereact": ">=9.6.5",
    "react": ">=18.2",
    "react-dom": ">=18.3.1",
    "react-router-dom": ">=6.28.2",
    "react-toastify": ">=10.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
